rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        (request.auth.token.email == 'smartdestinyonyekachi@gmail.com' || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isValidWaitlistEntry(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.email is string &&
             data.email.size() <= 150 &&
             data.email.matches('^[^@]+@[^@]+\\.[a-zA-Z]{2,}$') &&
             data.createdAt == request.time;
    }

    match /waitlist/{waitlistId} {
      allow create: if isValidId(waitlistId) && isValidWaitlistEntry(incoming());
      allow read, delete: if true;
      allow update: if false;
    }

    match /admins/{adminId} {
      allow read, delete, create, update: if isAdmin();
    }
  }
}
